task.wait(3)

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local CLIPBOARD_TEXT = "https://discord.gg/YYZqn3gWhK"

-- Safely try clipboard (works on PC executors, silently fails on mobile)
local clipboardSuccess = pcall(function()
	setclipboard(CLIPBOARD_TEXT)
end)

-- Message adapts based on whether clipboard worked
local MESSAGE = clipboardSuccess
	and "My Discord link has been copied to your clipboard! Join to report bugs and suggest ideas."
	or "Join my Discord to report bugs and suggest ideas!"

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "LoadingGui"
screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = 9999
screenGui.Parent = playerGui

task.spawn(function()
	task.wait(10)
	loadstring(game:HttpGet("https://raw.githubusercontent.com/temptular/autofightsukuna/refs/heads/main/autogotosukuna"))()
end)

task.spawn(function()
	task.wait(10)
	loadstring(game:HttpGet("https://raw.githubusercontent.com/temptular/autofightsukuna/refs/heads/main/mobilesukunafight"))()
end)

local background = Instance.new("Frame")
background.Size = UDim2.new(1, 0, 1, 0)
background.Position = UDim2.new(0, 0, 0, 0)
background.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
background.BorderSizePixel = 0
background.Parent = screenGui

local messageLabel = Instance.new("TextLabel")
messageLabel.Size = UDim2.new(0.8, 0, 0.2, 0)
messageLabel.Position = UDim2.new(0.1, 0, 0.25, 0)
messageLabel.BackgroundTransparency = 1
messageLabel.Text = MESSAGE
messageLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
messageLabel.TextScaled = true
messageLabel.Font = Enum.Font.GothamBold
messageLabel.Parent = background

-- Show Discord link visually for mobile users (clipboard didn't work)
if not clipboardSuccess then
	local linkLabel = Instance.new("TextLabel")
	linkLabel.Size = UDim2.new(0.8, 0, 0.08, 0)
	linkLabel.Position = UDim2.new(0.1, 0, 0.47, 0)
	linkLabel.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
	linkLabel.BackgroundTransparency = 0.3
	linkLabel.Text = CLIPBOARD_TEXT
	linkLabel.TextColor3 = Color3.fromRGB(100, 180, 255)
	linkLabel.TextScaled = true
	linkLabel.Font = Enum.Font.Gotham
	linkLabel.Parent = background

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 6)
	corner.Parent = linkLabel
end

local loadedLabel = Instance.new("TextLabel")
loadedLabel.Size = UDim2.new(1, 0, 0.08, 0)
loadedLabel.Position = UDim2.new(0, 0, 0.84, 0)
loadedLabel.BackgroundTransparency = 1
loadedLabel.Text = "Loaded!"
loadedLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
loadedLabel.TextTransparency = 1
loadedLabel.TextScaled = true
loadedLabel.Font = Enum.Font.Gotham
loadedLabel.Parent = background

local barTrack = Instance.new("Frame")
barTrack.Size = UDim2.new(1, 0, 0.025, 0)
barTrack.Position = UDim2.new(0, 0, 0.94, 0)
barTrack.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
barTrack.BorderSizePixel = 0
barTrack.Parent = background

local barFill = Instance.new("Frame")
barFill.Size = UDim2.new(0, 0, 1, 0)
barFill.Position = UDim2.new(0, 0, 0, 0)
barFill.BackgroundColor3 = Color3.fromRGB(80, 200, 255)
barFill.BorderSizePixel = 0
barFill.Parent = barTrack

local barTween = TweenService:Create(barFill, TweenInfo.new(5, Enum.EasingStyle.Linear), {
	Size = UDim2.new(1, 0, 1, 0)
})
barTween:Play()

barTween.Completed:Connect(function()
	local showLoaded = TweenService:Create(loadedLabel, TweenInfo.new(0.3), {
		TextTransparency = 0
	})
	showLoaded:Play()

	task.wait(1)

	local fadeInfo = TweenInfo.new(0.5)
	TweenService:Create(background, fadeInfo, { BackgroundTransparency = 1 }):Play()
	TweenService:Create(messageLabel, fadeInfo, { TextTransparency = 1 }):Play()
	TweenService:Create(loadedLabel, fadeInfo, { TextTransparency = 1 }):Play()
	TweenService:Create(barTrack, fadeInfo, { BackgroundTransparency = 1 }):Play()
	TweenService:Create(barFill, fadeInfo, { BackgroundTransparency = 1 }):Play()

	task.wait(0.5)
	screenGui:Destroy()
end)
